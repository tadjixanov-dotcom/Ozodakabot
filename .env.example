# Telegram
BOT_TOKEN=
ADMIN_IDS=

# Ma'lumotlar bazasi (SQLite default, PostgreSQL uchun: postgresql+asyncpg://user:pass@host:5432/dbname)
DATABASE_URL=sqlite+aiosqlite:///./news_bot.db

# Standart sozlamalar
DEFAULT_TIMEZONE=Asia/Tashkent
DEFAULT_LANGUAGE=uz
DEFAULT_DAILY_LIMIT=10

# Tashqi yangilik API'lari (ixtiyoriy)
NEWS_API_KEY=
GDELT_ENABLED=true

# AI tarjima/qisqartirish (bo'sh qoldirilsa bot AIsiz ishlaydi)
# Variantlar: gemini | anthropic
AI_PROVIDER=gemini
AI_API_KEY=
AI_MODEL=gemini-flash-latest

# Log darajasi
LOG_LEVEL=INFO

# Yig'ish va yuborish sozlamalari
FETCH_INTERVAL_MINUTES=15
DIGEST_CHECK_INTERVAL_MINUTES=5
MAX_ARTICLE_AGE_HOURS=48
REALTIME_IMPORTANCE_THRESHOLD=0.8
CRITICAL_IMPORTANCE_THRESHOLD=0.9
MAX_MESSAGES_PER_HOUR=20
EXPLORATION_RATE=0.12
REQUEST_TIMEOUT_SECONDS=20
